# Copy this file to ".env" (same folder) and fill in your own values.
# Never commit your real ".env" file - it contains a secret token.

# Azure DevOps Personal Access Token (Settings > Personal Access Tokens in Azure DevOps).
# Needs read access to Test Plans and Work Items.
AZDO_PAT=your-personal-access-token-here

# Your Azure DevOps organization name (the part right after dev.azure.com/ in your URL).
AZDO_ORG=your-organization-name

# Your Azure DevOps project name.
AZDO_PROJECT=your-project-name

# Skips the Microsoft sign-in screen entirely. Must match VITE_SKIP_AUTH in
# client/.env. Handy for local tryouts since AZDO_PAT above is your own
# personal token anyway; leave unset (or "false") for anything resembling a
# real deployment.
SKIP_AUTH=true

# Azure Entra ID app registration details. Only needed when SKIP_AUTH above
# is unset/false - ignored entirely while the Microsoft sign-in is skipped.
ENTRA_TENANT_ID=your-tenant-id
ENTRA_CLIENT_ID=your-client-id

# Comma-separated emails, or an email domain, allowed to sign in. Only used
# when SKIP_AUTH is unset/false.
PRIVILEGED_ALLOWLIST=
PRIVILEGED_DOMAIN=your-company.com

# Comma-separated list of origins allowed to call this API (CORS).
# Include your GitHub Pages URL in production, e.g.:
# https://your-org.github.io
CORS_ORIGIN=http://localhost:3000



# Comma-separated list of email addresses to receive emailed reports
# triggered from the dashboard's export menu.
SEND_MAIL_TO=your-email@example.com

# Enables the "Email report" export option on the dashboard. Must also
# match VITE_ENABLE_EMAIL_REPORT in client/.env.
ENABLE_EMAIL_REPORT=false

# SMTP credentials used to send the emailed report (with the PDF attached).
# For Office 365 / Exchange Online: smtp.office365.com, port 587,
# SMTP_SECURE=false (STARTTLS), and the mailbox's password (or an app
# password if MFA is enabled on that mailbox).
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-mailbox@your-company.com
SMTP_PASS=your-password-or-app-password
MAIL_FROM=your-mailbox@your-company.com

# Enables the /api/release-readiness endpoint (release exit-criteria gate,
# sprint completion & carry-over, sprint-over-sprint pass rate delta,
# blocking defects at release). Must also match VITE_ENABLE_RELEASE_READINESS
# in client/.env.
ENABLE_RELEASE_READINESS=false

# Release gate targets (optional - defaults shown below match the org's
# formal exit-criteria doc, code_coverage.md). RAG is Red if any BLOCK
# criterion fails, Amber if only a WARN criterion (Medium/Low severity
# defects open) fails, Green otherwise.
RELEASE_GATE_TESTS_EXECUTED_TARGET_PCT=100
RELEASE_GATE_TESTS_PASSED_TARGET_PCT=95
RELEASE_GATE_REQUIREMENTS_COVERAGE_TARGET_PCT=95

# Enables the Teams "bugs reported today" daily summary.
ENABLE_TEAMS_NOTIFICATIONS=false

# Incoming Webhook URL for the Teams channel (Channel > ... > Connectors >
# Incoming Webhook). Required when ENABLE_TEAMS_NOTIFICATIONS=true.
TEAMS_WEBHOOK_URL=

# Cron expression (node-cron syntax) for the "bugs reported today" report.
# Default: 17:45, Monday-Friday. Sends nothing on days with zero new bugs.
TEAMS_DAILY_SUMMARY_CRON=45 17 * * 1-5

# IANA timezone the cron expression above is evaluated in.
TEAMS_SUMMARY_TIMEZONE=Europe/Rome

# Name used in the "Hey <name>, N bug(s) were created today" greeting.
TEAMS_GREETING_NAME=team

# Enables writing a daily copy of the Sprint Defect Report PDF to a local
# folder (e.g. a synced OneDrive/SharePoint folder, so it shows up in Teams).
ENABLE_SPRINT_REPORT_EXPORT=false

# Absolute folder path the daily PDF is written into. Required when
# ENABLE_SPRINT_REPORT_EXPORT=true.
SPRINT_REPORT_EXPORT_PATH=

# Cron expression (node-cron syntax) for the daily Sprint Defect Report file
# export. Default: 18:00 every day.
SPRINT_REPORT_EXPORT_CRON=0 18 * * *

# IANA timezone the cron expression above is evaluated in.
SPRINT_REPORT_EXPORT_TIMEZONE=Europe/Rome