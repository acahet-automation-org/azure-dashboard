# Copy this file to ".env" (same folder) and fill in your own values.
# Never commit your real ".env" file - it contains secrets.

# Azure DevOps Personal Access Token (Settings > Personal Access Tokens in Azure DevOps).
# Needs read access to Test Plans and Work Items.
# DEV-ONLY FALLBACK: only used while SKIP_AUTH=true below. Real deployments
# authenticate to Azure DevOps via the OAuth On-Behalf-Of flow (see
# ENTRA_CLIENT_SECRET) and never touch this value.
AZDO_PAT=your-personal-access-token-here

# Your Azure DevOps organization name (the part right after dev.azure.com/ in your URL).
AZDO_ORG=your-organization-name

# Your Azure DevOps project name.
AZDO_PROJECT=your-project-name

# Skips the Microsoft sign-in screen entirely. Must match VITE_SKIP_AUTH in
# client/.env. Handy for local tryouts since AZDO_PAT above is your own
# personal token anyway; leave unset (or "false") for anything resembling a
# real deployment.
SKIP_AUTH=true

# Azure Entra ID app registration details. Only needed when SKIP_AUTH above
# is unset/false - ignored entirely while the Microsoft sign-in is skipped.
ENTRA_TENANT_ID=your-tenant-id
ENTRA_CLIENT_ID=your-client-id

# Client secret for the app registration (Certificates & secrets in Azure
# Portal). Required whenever SKIP_AUTH is unset/false - used to exchange the
# user's API access token for an Azure DevOps token via OAuth On-Behalf-Of.
ENTRA_CLIENT_SECRET=your-client-secret

# Comma-separated emails, or an email domain, allowed to sign in. Only used
# when SKIP_AUTH is unset/false.
PRIVILEGED_ALLOWLIST=
PRIVILEGED_DOMAIN=your-company.com

# Comma-separated list of origins allowed to call this API (CORS).
# Include your GitHub Pages URL in production, e.g.:
# https://your-org.github.io
CORS_ORIGIN=http://localhost:3000
