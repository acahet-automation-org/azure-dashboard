# Copy this file to ".env" (same folder) and fill in your own values.

# Azure Entra ID app registration details (Azure Portal > App registrations).
VITE_ENTRA_TENANT_ID=your-tenant-id
VITE_ENTRA_CLIENT_ID=your-client-id
VITE_ENTRA_API_SCOPE=api://your-client-id/access_as_user
VITE_ENTRA_REDIRECT_URI=http://localhost:3000

# Base URL of the backend API. Leave empty for local dev (Vite proxies /api
# to localhost:3001 - see vite.config.ts). In production, set this to your
# deployed backend URL, e.g. https://azure-dashboard-api.onrender.com
VITE_API_BASE_URL=
